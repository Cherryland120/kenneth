  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nexport default function App() {\n  return <div></div>;\n}\n"
      replacement_content: "import React, { useState, useRef } from \'react\';\nimport { Mic, Upload, StopCircle, Play, FileAudio, RefreshCw, Languages } from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\nexport default function App() {\n  const [isRecording, setIsRecording] = useState(false);\n  const [audioUrl, setAudioUrl] = useState<string | null>(null);\n  const [audioBlob, setAudioBlob] = useState<Blob | null>(null);\n  const [transcription, setTranscription] = useState<string>(\'\');\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n  const [mode, setMode] = useState<\'transcribe\' | \'translate\'>(\'transcribe\');\n\n  const mediaRecorderRef = useRef<MediaRecorder | null>(null);\n  const chunksRef = useRef<BlobPart[]>([]);\n\n  const startRecording = async () => {\n    try {\n      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });\n      const mediaRecorder = new MediaRecorder(stream);\n      mediaRecorderRef.current = mediaRecorder;\n      chunksRef.current = [];\n\n      mediaRecorder.ondataavailable = (e) => {\n        if (e.data.size > 0) chunksRef.current.push(e.data);\n      };\n\n      mediaRecorder.onstop = () => {\n        const blob = new Blob(chunksRef.current, { type: \'audio/webm\' });\n        setAudioBlob(blob);\n        setAudioUrl(URL.createObjectURL(blob));\n        stream.getTracks().forEach((track) => track.stop());\n      };\n\n      mediaRecorder.start();\n      setIsRecording(true);\n      setError(null);\n    } catch (err) {\n      setError(\'Microphone access denied. Please ensure you have granted permission.\');\n    }\n  };\n\n  const stopRecording = () => {\n    mediaRecorderRef.current?.stop();\n    setIsRecording(false);\n  };\n\n  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (file) {\n      setAudioBlob(file);\n      setAudioUrl(URL.createObjectURL(file));\n      setError(null);\n    }\n  };\n\n  const handleProcessAudio = async () => {\n    if (!audioBlob) return;\n    setIsLoading(true);\n    setError(null);\n\n    try {\n      const formData = new FormData();\n      formData.append(\'file\', audioBlob);\n\n      // Attempt to communicate with the local FastAPI server.\n      const res = await fetch(`http://localhost:8000/api/${mode}`, {\n        method: \'POST\',\n        body: formData,\n      });\n      \n      if (!res.ok) {\n        throw new Error(\'Backend not reachable\');\n      }\n      \n      const data = await res.json();\n      setTranscription(data.text || data.error || \'No output received.\');\n    } catch (err) {\n      // Fallback message for AI Studio Preview where FastAPI backend is not running locally\n      setTimeout(() => {\n        setTranscription(\"This is an AI Studio preview fallback. The environment runs exclusively on Node.js, so the Python backend could not be booted.\\n\\nTo see real translations:\\n1. Open your terminal in this directory.\\n2. Run \'pip install -r requirements.txt\'\\n3. Run \'uvicorn fastapi_app:app --reload\'\\n4. Open the App UI again! This fetch request is statically bound to http://localhost:8000.\");\n        setIsLoading(false);\n      }, 1500);\n      return;\n    }\n\n    setIsLoading(false);\n  };\n\n  const reset = () => {\n    setAudioBlob(null);\n    setAudioUrl(null);\n    setTranscription(\'\');\n    setError(null);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-50 text-slate-900 font-sans p-6 md:p-12\">\n      <div className=\"max-w-3xl mx-auto space-y-8\">\n        <header className=\"text-center space-y-3\">\n          <div className=\"inline-flex items-center justify-center p-3 bg-indigo-100 text-indigo-700 rounded-full mb-2\">\n            <Languages className=\"w-8 h-8\" />\n          </div>\n          <h1 className=\"text-3xl md:text-4xl font-bold tracking-tight text-slate-900\">Igbo Speech Translator</h1>\n          <p className=\"text-slate-500 max-w-xl mx-auto\">\n            Powered by <code className=\"text-xs bg-slate-200 px-1 py-0.5 rounded\">whisper-large-v3-igbo</code>. \n            Note: Whisper is an audio-to-text model, so input is accepted via microphone or audio file upload.\n          </p>\n        </header>\n\n        <main className=\"bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden\">\n          {/* Mode Selector */}\n          <div className=\"grid grid-cols-2 text-sm font-medium border-b border-slate-200 bg-slate-50\">\n            <button\n              onClick={() => setMode(\'transcribe\')}\n              className={`p-4 transition-all duration-200 ${\n                mode === \'transcribe\'\n                  ? \'bg-white text-indigo-700 border-t-2 border-t-indigo-600 shadow-sm relative z-10\'\n                  : \'text-slate-500 hover:text-slate-700 hover:bg-slate-100 border-t-2 border-t-transparent\'\n              }`}\n            >\n              Igbo Audio \342\206\222 Igbo Text\n            </button>\n            <button\n              onClick={() => setMode(\'translate\')}\n              className={`p-4 transition-all duration-200 ${\n                mode === \'translate\'\n                  ? \'bg-white text-indigo-700 border-t-2 border-t-indigo-600 shadow-sm relative z-10\'\n                  : \'text-slate-500 hover:text-slate-700 hover:bg-slate-100 border-t-2 border-t-transparent\'\n              }`}\n            >\n              Igbo Audio \342\206\222 English Text\n            </button>\n          </div>\n\n          <div className=\"p-6 md:p-10 space-y-8\">\n            <AnimatePresence mode=\"wait\">\n              {!audioBlob ? (\n                <motion.div\n                  key=\"input-methods\"\n                  initial={{ opacity: 0, y: 10 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  exit={{ opacity: 0, scale: 0.98 }}\n                  className=\"grid md:grid-cols-2 gap-4\"\n                >\n                  {/* Record Control */}\n                  <div className=\"border-2 border-dashed border-slate-200 rounded-2xl p-8 flex flex-col items-center justify-center space-y-4 hover:border-indigo-300 hover:bg-slate-50 transition-colors group\">\n                    <button\n                      onClick={isRecording ? stopRecording : startRecording}\n                      className={`p-5 rounded-full transition-all shadow-sm ${\n                        isRecording\n                          ? \'bg-red-100 text-red-600 hover:bg-red-200 animate-pulse\'\n                          : \'bg-indigo-100 text-indigo-600 hover:bg-indigo-200 group-hover:scale-105\'\n                      }`}\n                    >\n                      {isRecording ? <StopCircle className=\"w-8 h-8\" /> : <Mic className=\"w-8 h-8\" />}\n                    </button>\n                    <div className=\"text-center\">\n                      <p className=\"font-semibold text-slate-800\">\n                        {isRecording ? \'Listening...\' : \'Record Audio\'}\n                      </p>\n                      <p className=\"text-xs text-slate-400 mt-1\">Directly via microphone</p>\n                    </div>\n                  </div>\n\n                  {/* Upload Control */}\n                  <label className=\"border-2 border-dashed border-slate-200 rounded-2xl p-8 flex flex-col items-center justify-center space-y-4 hover:border-indigo-300 hover:bg-slate-50 transition-colors cursor-pointer group\">\n                    <input\n                      type=\"file\"\n                      accept=\"audio/*\"\n                      className=\"hidden\"\n                      onChange={handleFileUpload}\n                    />\n                    <div className=\"p-5 rounded-full bg-slate-100 text-slate-600 group-hover:bg-slate-200 group-hover:scale-105 transition-all shadow-sm\">\n                      <Upload className=\"w-8 h-8\" />\n                    </div>\n                    <div className=\"text-center gap-1\">\n                      <p className=\"font-semibold text-slate-800\">Upload File</p>\n                      <p className=\"text-xs text-slate-400 mt-1\">MP3, WAV, or WEBM format</p>\n                    </div>\n                  </label>\n                </motion.div>\n              ) : (\n                <motion.div\n                  key=\"preview-player\"\n                  initial={{ opacity: 0, scale: 0.98 }}\n                  animate={{ opacity: 1, scale: 1 }}\n                  className=\"space-y-6\"\n                >\n                  <div className=\"bg-slate-50 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between border border-slate-200 gap-4\">\n                    <div className=\"flex items-center space-x-4 w-full\">\n                      <div className=\"p-3 bg-indigo-100 text-indigo-600 rounded-xl\">\n                        <FileAudio className=\"w-6 h-6\" />\n                      </div>\n                      <div className=\"flex-1 overflow-hidden\">\n                        <p className=\"font-semibold text-slate-800\">Audio Captured</p>\n                        <audio src={audioUrl || \'\'} controls className=\"h-10 mt-2 w-full max-w-full\" />\n                      </div>\n                    </div>\n                    <button\n                      onClick={reset}\n                      className=\"p-3 text-slate-400 hover:text-slate-700 bg-white rounded-xl shadow-sm border border-slate-200 transition-all hover:bg-slate-50 flex-shrink-0\"\n                      title=\"Clear audio and start over\"\n                    >\n                      <RefreshCw className=\"w-5 h-5\" />\n                    </button>\n                  </div>\n\n                  {!transcription && (\n                    <button\n                      onClick={handleProcessAudio}\n                      disabled={isLoading}\n                      className=\"w-full py-4 bg-indigo-600 text-white rounded-2xl font-semibold shadow-md hover:bg-indigo-700 transition-all flex items-center justify-center space-x-3 disabled:opacity-70 disabled:cursor-not-allowed hover:shadow-lg active:scale-[0.98]\"\n                    >\n                      {isLoading ? (\n                        <>\n                          <RefreshCw className=\"w-5 h-5 animate-spin\" />\n                          <span>Feeding into Model...</span>\n                        </>\n                      ) : (\n                        <>\n                          <Play className=\"w-5 h-5\" />\n                          <span>{mode === \'transcribe\' ? \'Transcribe Speech\' : \'Perform Translation\'}</span>\n                        </>\n                      )}\n                    </button>\n                  )}\n                </motion.div>\n              )}\n            </AnimatePresence>\n\n            {error && (\n              <div className=\"p-4 bg-red-50 text-red-700 rounded-xl text-sm border border-red-100 flex items-center\">\n                <span className=\"font-semibold\">{error}</span>\n              </div>\n            )}\n\n            {transcription && (\n              <motion.div\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                className=\"mt-8 space-y-3 border-t border-slate-100 pt-8\"\n              >\n                <div className=\"flex items-center justify-between\">\n                  <h3 className=\"font-semibold text-slate-900 flex items-center\">\n                    <span className=\"w-2 h-2 rounded-full bg-green-500 mr-2\"></span>\n                    {mode === \'transcribe\' ? \'Igbo Transcription\' : \'English Translation\'}\n                  </h3>\n                </div>\n                <div className=\"p-6 bg-slate-50 border border-slate-200 rounded-2xl\">\n                  <p className=\"whitespace-pre-wrap leading-relaxed text-slate-800 font-medium\">\n                    {transcription}\n                  </p>\n                </div>\n              </motion.div>\n            )}\n          </div>\n        </main>\n      </div>\n    </div>\n  );\n}\n"
    }
